<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/light_green">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Butones"
        android:textColor="@color/primary_green"
        android:textSize="45sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="142dp"
        android:layout_height="143dp"
        android:src="@drawable/boton"
        android:layout_marginBottom="10dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Acciones interactivas que disparan eventos en la aplicación."
        android:textAlignment="center"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ejemplos interactivos:"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/primary_green"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="25dp" />

        <Button
            android:id="@+id/btnStandard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estándar"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/primary_green" />

        <ImageButton
            android:id="@+id/btnImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_camera"
            android:backgroundTint="@color/secondary_green" />

    <Button
        android:id="@+id/btnLongClick"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Mantén presionado"
        android:layout_marginTop="12dp"
        android:backgroundTint="#FF9800" />

    <Button
        android:id="@+id/btnCounter"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Veces presionado: 0"
        android:layout_marginTop="12dp"
        android:backgroundTint="#2196F3" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabExample"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:src="@android:drawable/ic_input_add"
        app:tint="@color/white"
        android:backgroundTint="@color/primary_green" />

</LinearLayout>