<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/light_green">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Elementos de Información"
        android:textSize="45sp"
        android:textColor="@color/primary_green"
        android:gravity="center"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <ImageView
        android:id="@+id/imageView5"
        android:layout_width="143dp"
        android:layout_height="146dp"
        android:src="@drawable/info" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Componentes que muestran contenido al usuario sin esperar interacción directa. Incluyen textos informativos (TextView), imágenes o fotos (ImageView) e indicadores visuales de que algo está en proceso (ProgressBar), como una carga o descarga."
        android:textAlignment="center"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A continuación se muestran unos ejemplos de elementos de información:"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/primary_green"
        android:textStyle="bold"
        android:layout_marginTop="20dp" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="152dp"
        android:layout_height="107dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/datos" />

    <TextView
        android:id="@+id/tvStatusInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listo para procesar"
        android:layout_marginTop="24dp"
        android:textSize="16sp" />

    <ProgressBar
        android:id="@+id/progressBarDemo"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnLoadInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Simular Carga de Datos"
        android:backgroundTint="@color/primary_green"
        android:textColor="@color/white"
        android:layout_marginTop="32dp" />

</LinearLayout>