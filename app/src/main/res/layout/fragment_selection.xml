<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/light_green">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="Elementos de Selección"
        android:gravity="center"
        android:textColor="@color/primary_green"
        android:textSize="45sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="170dp"
        android:layout_height="161dp"
        android:src="@drawable/elegir" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Componentes que permiten al usuario elegir entre diferentes opciones. Incluyen casillas para marcar varias opciones (CheckBox), botones para elegir una sola opción dentro de un grupo (RadioButton) e interruptores para activar o desactivar funciones (Switch)."
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A continuación se muestran unos ejemplos de elementos de selección:"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/primary_green"
        android:textStyle="bold"
        android:layout_marginTop="20dp" />

    <CheckBox
        android:id="@+id/cbOption"
        android:layout_width="240dp"
        android:layout_height="42dp"
        android:text="Aceptar términos y condiciones"
        android:textSize="16sp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="15dp"/>

    <Switch
        android:id="@+id/switchDemo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notificaciones activas"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona una opción:"
        android:layout_marginTop="24dp"
        android:textStyle="italic" />

    <RadioGroup
        android:id="@+id/radioGroupDemo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <RadioButton
            android:id="@+id/radio1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opción A (Prioridad)" />

        <RadioButton
            android:id="@+id/radio2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opción B (Secundaria)" />
    </RadioGroup>

</LinearLayout>